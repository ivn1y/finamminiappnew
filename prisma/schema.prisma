// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id              String   @id @default(cuid())
  telegramId      BigInt   @unique
  username        String?
  firstName       String
  lastName        String?
  photoUrl        String?
  languageCode    String?
  isPremium       Boolean  @default(false)
  allowsWriteToPm Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Broadcast {
  id        String   @id @default(cuid())
  message   String
  sentAt    DateTime @default(now())
  sentCount Int      @default(0)
  failCount Int      @default(0)
  status    String   @default("pending")
}

/// Участник потока /bugbounty (идентифицируется стабильным ключом в localStorage)
model BugBountyParticipant {
  id               String              @id @default(cuid())
  participantKey   String              @unique
  email            String              @unique
  displayName      String
  phone            String
  passwordHash     String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  reports          BugBountyReport[]
}

enum BugBountyReportStatus {
  PENDING
  ACCEPTED
  REJECTED
}

model BugBountyReport {
  id             String                  @id @default(cuid())
  participantId  String
  participant    BugBountyParticipant    @relation(fields: [participantId], references: [id], onDelete: Cascade)
  title          String
  description    String
  /// JSON: [{ "id": string, "mime": string, "kind": "image" | "video", "name": string }]
  attachments    Json?
  status            BugBountyReportStatus   @default(PENDING)
  /// Виден участнику, если статус REJECTED
  rejectionComment  String?
  reviewedAt        DateTime?
  createdAt         DateTime                @default(now())

  @@index([participantId])
  @@index([createdAt])
  @@index([status])
}

